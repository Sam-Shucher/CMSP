DB_HOST=localhost
DB_USER=mini_library_user
DB_PASS=your_password_here
DB_NAME=mini_library
JWT_SECRET=change_this_to_a_long_random_string
# Development: 3001 (Vite dev server proxies /api here).
# Production (Raspberry Pi): 4233 — the backend serves the built frontend too,
# and the Cloudflare Tunnel points at this port. scripts/rpi-setup.sh sets this.
PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development